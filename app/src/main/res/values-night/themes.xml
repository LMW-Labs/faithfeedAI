<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FaithfeedAI" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.SplashScreen" parent="Theme.FaithfeedAI">
        <item name="android:windowSplashScreenBackground">#0D0D0D</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/omega</item>
        <item name="postSplashScreenTheme">@style/Theme.FaithfeedAI</item>
    </style>
</resources>